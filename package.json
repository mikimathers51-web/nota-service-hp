{
  "name": "nota-service-hp",
  "version": "1.0.0",
  "description": "Aplikasi Nota Service HP dengan Capacitor",
  "main": "index.js",
  "scripts": {
    "build": "node scripts/build.js",
    "sync": "npx cap sync",
    "android": "npx cap open android",
    "add-android": "npx cap add android",
    "build-android": "npm run build && npx cap sync android && cd android && ./gradlew assembleDebug",
    "build-release": "npm run build && npx cap sync android && cd android && ./gradlew assembleRelease"
  },
  "keywords": ["capacitor", "mobile", "android", "service", "nota", "hp"],
  "author": "Toko Service HP",
  "license": "MIT",
  "dependencies": {
    "@capacitor-community/bluetooth-serial": "^4.0.0",
    "@capacitor-community/contacts": "^6.0.0",
    "@capacitor/android": "^6.1.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/camera": "^6.0.0",
    "@capacitor/core": "^6.1.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/share": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.0",
    "typescript": "^5.0.0"
  }
}
